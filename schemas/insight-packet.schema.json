{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:bphr:schema:insight-packet",
  "title": "Insight Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "status",
    "theme_id",
    "anchor",
    "claim",
    "source_refs",
    "created_by"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^insight_[a-z0-9][a-z0-9_-]*$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "needs_revision", "approved", "rejected"]
    },
    "theme_id": {
      "type": "string",
      "pattern": "^theme_[a-z0-9][a-z0-9_-]*$"
    },
    "anchor": {
      "$ref": "#/$defs/passage_anchor"
    },
    "claim": {
      "type": "string",
      "minLength": 1,
      "description": "Concise claim supported by the cited BibleProject source spans."
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_ref"
      }
    },
    "related_pairing_packet_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^pair_[a-z0-9][a-z0-9_-]*$"
      },
      "uniqueItems": true
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_by": {
      "type": "string"
    },
    "review_notes": {
      "type": "string"
    }
  },
  "$defs": {
    "passage_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["translation", "book", "start_chapter", "start_verse", "end_chapter", "end_verse"],
      "properties": {
        "translation": {
          "type": "string",
          "const": "BSB"
        },
        "book": {
          "type": "string",
          "minLength": 1
        },
        "start_chapter": {
          "type": "integer",
          "minimum": 1
        },
        "start_verse": {
          "type": "integer",
          "minimum": 1
        },
        "end_chapter": {
          "type": "integer",
          "minimum": 1
        },
        "end_verse": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "span"],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^src_[a-z0-9][a-z0-9_-]*$"
        },
        "span": {
          "$ref": "#/$defs/source_span"
        },
        "excerpt": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "source_span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_seconds", "end_seconds"],
      "properties": {
        "start_seconds": {
          "type": "number",
          "minimum": 0
        },
        "end_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
