{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:bphr:schema:app-insight-bundle",
  "title": "App Insight Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "themes", "sourceRecords", "insights"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "status", "generatedAt", "policyNote"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "generatedAt": { "type": "string", "minLength": 1 },
        "policyNote": { "type": "string", "minLength": 1 }
      }
    },
    "themes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/theme" } },
    "sourceRecords": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/sourceRecord" } },
    "insights": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/insight" } }
  },
  "$defs": {
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "shortName", "color", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "shortName": { "type": "string", "minLength": 1 },
        "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "sourceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "type", "pageUrl", "description", "sourceStatus"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["podcast", "video", "guide", "article"] },
        "pageUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "sourceStatus": { "type": "string", "minLength": 1 },
        "audioUrl": { "type": "string", "format": "uri" },
        "episodeChapters": { "type": "array", "items": { "$ref": "#/$defs/episodeChapter" } }
      }
    },
    "episodeChapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "startSeconds", "endSeconds", "label"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "startSeconds": { "type": "integer", "minimum": 0 },
        "endSeconds": { "type": "integer", "exclusiveMinimum": 0 },
        "label": { "type": "string", "pattern": "^[0-9]{1,2}:[0-9]{2}–[0-9]{1,2}:[0-9]{2}$" }
      }
    },
    "insight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "status", "themeIds", "title", "shortLabel", "explanation", "pastoralUse", "anchors", "originalLanguages", "sourceSpans"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["hyperlink", "helpful-info"] },
        "status": { "type": "string", "minLength": 1 },
        "themeIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "title": { "type": "string", "minLength": 1 },
        "shortLabel": { "type": "string", "minLength": 1 },
        "explanation": { "type": "string", "minLength": 1 },
        "pastoralUse": { "type": "string", "minLength": 1 },
        "anchors": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/anchor" } },
        "originalLanguages": { "type": "array", "items": { "$ref": "#/$defs/originalLanguage" } },
        "sourceSpans": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/sourceSpan" } }
      }
    },
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verseId", "ref", "selector", "shape", "color", "note"],
      "properties": {
        "verseId": { "type": "string", "pattern": "^[1-3]?[A-Z]{2,3}\\.[0-9]+\\.[0-9]+$" },
        "ref": { "type": "string", "minLength": 1 },
        "selector": { "type": "string", "minLength": 1 },
        "shape": { "type": "string", "enum": ["underline", "circle", "square", "ribbon"] },
        "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "originalLanguage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "term", "transliteration", "gloss", "explanation"],
      "properties": {
        "language": { "type": "string", "minLength": 1 },
        "term": { "type": "string", "minLength": 1 },
        "transliteration": { "type": "string", "minLength": 1 },
        "gloss": { "type": "string", "minLength": 1 },
        "explanation": { "type": "string", "minLength": 1 }
      }
    },
    "sourceSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "evidenceNote"],
      "properties": {
        "sourceId": { "type": "string", "minLength": 1 },
        "startSeconds": { "type": "integer", "minimum": 0 },
        "endSeconds": { "type": "integer", "exclusiveMinimum": 0 },
        "timestampLabel": { "type": "string", "pattern": "^[0-9]{1,2}:[0-9]{2}–[0-9]{1,2}:[0-9]{2}$" },
        "evidenceNote": { "type": "string", "minLength": 1 }
      }
    }
  }
}
