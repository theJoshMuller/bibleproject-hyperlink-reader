{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:bphr:schema:app-bible",
  "title": "App Bible Translation Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["translation", "books"],
  "properties": {
    "translation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "abbreviation", "license", "sourceUrl", "generatedAt"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "abbreviation": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 },
        "sourceUrl": { "type": "string", "format": "uri" },
        "generatedAt": { "type": "string", "minLength": 1 }
      }
    },
    "books": {
      "type": "array",
      "minItems": 66,
      "items": { "$ref": "#/$defs/book" }
    }
  },
  "$defs": {
    "book": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "testament", "chapters"],
      "properties": {
        "id": { "type": "string", "pattern": "^[1-3]?[A-Z]{2,3}$" },
        "name": { "type": "string", "minLength": 1 },
        "testament": { "type": "string", "enum": ["OT", "NT"] },
        "chapters": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/chapter" } }
      }
    },
    "chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "verses"],
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "verses": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/verse" } }
      }
    },
    "verse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "bookId", "bookName", "chapter", "verse", "text"],
      "properties": {
        "id": { "type": "string", "pattern": "^[1-3]?[A-Z]{2,3}\\.[0-9]+\\.[0-9]+$" },
        "bookId": { "type": "string", "pattern": "^[1-3]?[A-Z]{2,3}$" },
        "bookName": { "type": "string", "minLength": 1 },
        "chapter": { "type": "integer", "minimum": 1 },
        "verse": { "type": "integer", "minimum": 1 },
        "text": { "type": "string", "minLength": 1 }
      }
    }
  }
}
