{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:bphr:schema:source-pairing-packet",
  "title": "Source Pairing Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "status",
    "decision",
    "source_refs",
    "evidence",
    "created_by"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^pair_[a-z0-9][a-z0-9_-]*$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "needs_revision", "approved", "rejected"]
    },
    "decision": {
      "type": "string",
      "enum": ["paired", "ambiguous", "not_found", "rejected"]
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_source_id"],
      "properties": {
        "primary_source_id": {
          "type": "string",
          "pattern": "^src_[a-z0-9][a-z0-9_-]*$"
        },
        "candidate_source_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^src_[a-z0-9][a-z0-9_-]*$"
          },
          "uniqueItems": true
        },
        "candidate_urls": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "uniqueItems": true
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "summary"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["metadata", "title", "description", "transcript_span", "external_link", "reviewer_note", "other"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "source_id": {
            "type": "string",
            "pattern": "^src_[a-z0-9][a-z0-9_-]*$"
          },
          "span": {
            "$ref": "#/$defs/source_span"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_by": {
      "type": "string"
    },
    "review_notes": {
      "type": "string"
    }
  },
  "$defs": {
    "source_span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_seconds", "end_seconds"],
      "properties": {
        "start_seconds": {
          "type": "number",
          "minimum": 0
        },
        "end_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
